{
  "name": "came",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "came": "./dist/cli/came.js",
    "came-mcp": "./dist/cli/came-mcp.js"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:app-server": "vitest run tests/app-server",
    "test:foundation": "vitest run tests/foundation",
    "test:governance": "vitest run tests/governance",
    "test:handoff": "vitest run tests/handoff",
    "test:plugin": "vitest run tests/plugin",
    "test:control-plane": "vitest run tests/control-plane",
    "test:diagnostics": "vitest run tests/diagnostics tests/runtime/came-cli.test.ts",
    "test:runtime": "vitest run tests/runtime"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "ws": "8.21.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/ws": "8.18.1",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "packageManager": "pnpm@10.28.1"
}
